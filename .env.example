# Google Sheets backend
GOOGLE_SHEETS_ID=YOUR_GOOGLE_SHEETS_ID

# JSON string from Google service account credentials
# Keep as one-line JSON with escaped newlines (\\n) in private_key
GOOGLE_SERVICE_ACCOUNT_JSON=YOUR_GOOGLE_SERVICE_ACCOUNT_JSON

# Google Drive upload target folder ID (recommended: Shared Drive folder)
GOOGLE_DRIVE_FOLDER_ID=YOUR_GOOGLE_DRIVE_FOLDER_ID

# Optional fallback auth for Google Drive upload using OAuth refresh token.
# Recommended if you must upload into My Drive and cannot move to Shared Drive.
# Isi ketiganya sekaligus (all-or-nothing).
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=